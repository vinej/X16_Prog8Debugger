{
    "comments": {
        "lineComment": ";"
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        { "open": "{", "close": "}" },
        { "open": "[", "close": "]" },
        { "open": "(", "close": ")" },
        { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
        { "open": "'", "close": "'", "notIn": ["string", "comment"] }
    ],
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""],
        ["'", "'"]
    ],
    "folding": {
        "markers": {
            "start": "^\\s*%asm\\s*\\{\\{",
            "end": "^\\s*\\}\\}"
        }
    },
    "wordPattern": "[A-Za-z_][A-Za-z0-9_]*|%[a-z]+|\\$[0-9a-fA-F]+"
}
